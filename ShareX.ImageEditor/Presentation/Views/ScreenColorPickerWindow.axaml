<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ShareX.ImageEditor.Presentation.Views.ScreenColorPickerWindow"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Topmost="True"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        FontFamily="{DynamicResource ShareX.FontFamily.Default}"
        Foreground="{DynamicResource ShareX.Brush.Text}">
    <!-- The capture surface stays transparent so the target pixels remain visible. -->
    <Canvas x:Name="PickerSurface"
            Background="Transparent">
        <Border x:Name="PickerPreview"
            Width="128"
            Height="52"
            Padding="8"
            CornerRadius="8"
            Background="{DynamicResource ShareX.Brush.Background.Main}"
            BorderBrush="{DynamicResource ShareX.Brush.Border}"
            BorderThickness="1"
            BoxShadow="0 8 24 #66000000"
            IsHitTestVisible="False">
            <Grid ColumnDefinitions="36,*" ColumnSpacing="10">
                <Border x:Name="ColorPreview"
                        Width="36"
                        Height="36"
                        CornerRadius="5"
                        BorderBrush="{DynamicResource ShareX.Brush.Border}"
                        BorderThickness="1"/>

                <TextBlock x:Name="HexText"
                           Grid.Column="1"
                           Text="#000000"
                           FontFamily="{DynamicResource ShareX.FontFamily.Default}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ShareX.Brush.Text}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Canvas>
</Window>
