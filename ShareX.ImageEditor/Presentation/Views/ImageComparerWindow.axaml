<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ShareX.ImageEditor.Presentation.ViewModels"
        xmlns:controls="using:ShareX.ImageEditor.Presentation.Controls"
        xmlns:theming="using:ShareX.ImageEditor.Presentation.Theming"
        mc:Ignorable="d" d:DesignWidth="1180" d:DesignHeight="760"
        x:Class="ShareX.ImageEditor.Presentation.Views.ImageComparerWindow"
        x:DataType="vm:ImageComparerViewModel"
        Title="ShareX - Image Comparer"
        Width="1180"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Border.comparer-panel">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Background.Panel}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="TextBlock.path-text">
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
        </Style>
        <Style Selector="Image.preview-image">
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>
    </Window.Styles>

    <ThemeVariantScope RequestedThemeVariant="{x:Static theming:ThemeManager.ShareXDark}">
        <Grid Background="{DynamicResource ShareX.Brush.Background.Main}">
            <Grid RowDefinitions="Auto,*" Margin="16" RowSpacing="12">
                <Grid Grid.Row="0" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Classes="comparer-panel" Padding="12">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <TextBlock Grid.Column="0"
                                       Text="Image 1"
                                       FontSize="16"
                                       Foreground="{DynamicResource ShareX.Brush.Text}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Classes="path-text"
                                       VerticalAlignment="Center"
                                       Text="{Binding Image1Path, TargetNullValue='No image selected'}"/>
                            <Button Grid.Column="2" Classes="app-button" Content="Choose..." Command="{Binding SelectImage1Command}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Classes="comparer-panel" Padding="12">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <TextBlock Grid.Column="0"
                                       Text="Image 2"
                                       FontSize="16"
                                       Foreground="{DynamicResource ShareX.Brush.Text}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Classes="path-text"
                                       VerticalAlignment="Center"
                                       Text="{Binding Image2Path, TargetNullValue='No image selected'}"/>
                            <Button Grid.Column="2" Classes="app-button" Content="Choose..." Command="{Binding SelectImage2Command}"/>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Classes="comparer-panel" ClipToBounds="True">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0"
                                Background="{DynamicResource ShareX.Brush.Background.Toolbar}"
                                BorderBrush="{DynamicResource ShareX.Brush.Border}"
                                BorderThickness="0,0,0,1"
                                Padding="16,12">
                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="16">
                                <RadioButton Grid.Column="0" Content="Slider" GroupName="ComparisonMode"
                                             IsChecked="{Binding IsSliderMode}"/>
                                <RadioButton Grid.Column="1" Content="Diff View" GroupName="ComparisonMode"
                                             IsChecked="{Binding IsDiffViewMode}"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SimilarityText}"
                                           Foreground="{Binding SimilarityBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Background="{DynamicResource ShareX.Brush.Background.Panel}">
                            <TextBlock Text="Select Image 1 and Image 2 to show the comparison preview."
                                       IsVisible="{Binding !CanShowComparison}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="Normal"/>

                            <controls:ImageComparisonSlider LeftImage="{Binding DisplayedLeftImage}"
                                                            RightImage="{Binding DisplayedRightImage}"
                                                            IsVisible="{Binding IsSliderComparisonVisible}"
                                                            Margin="12"/>

                            <Image Classes="preview-image"
                                   Source="{Binding DiffPreview}"
                                   IsVisible="{Binding IsDiffComparisonVisible}"
                                   Margin="12"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ThemeVariantScope>
</Window>
