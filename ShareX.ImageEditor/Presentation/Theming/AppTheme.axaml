<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:ShareX.ImageEditor.Presentation.Theming">
    
    <FontFamily x:Key="ShareX.FontFamily.Default">Segoe UI, avares://Avalonia.Fonts.Inter/Assets#Inter</FontFamily>
    <FontFamily x:Key="ShareX.FontFamily.Icon">avares://ShareX.ImageEditor/Assets#lucide</FontFamily>
    <FontFamily x:Key="ShareX.FontFamily.Monospace">Cascadia Mono, Consolas, Courier New, Monospace</FontFamily>
    <x:Double x:Key="ShareX.FontSize.Default">13</x:Double>
    <x:Double x:Key="ShareX.Value.Accent.Foreground.DarkSwitchRatio">1.75</x:Double>

    <ResourceDictionary.ThemeDictionaries>

        <!-- ShareX Dark theme -->
        <ResourceDictionary x:Key="{x:Static helpers:ThemeManager.ShareXDark}">
            <Color x:Key="ShareX.Color.Accent.Start">#3E83F2</Color>
            <Color x:Key="ShareX.Color.Accent.End">#3975D5</Color>
            <Color x:Key="ShareX.Color.Accent.Foreground">#D8DADB</Color>

            <Color x:Key="ShareX.Color.Text">#D8DADB</Color>
            <Color x:Key="ShareX.Color.Text.Secondary">#D8DADB</Color>

            <Color x:Key="ShareX.Color.Background.Main">#272727</Color>
            <Color x:Key="ShareX.Color.Background.Panel">#242424</Color>
            <Color x:Key="ShareX.Color.Background.Popup">#2E2E2E</Color>
            <Color x:Key="ShareX.Color.Background.Toolbar">#222222</Color>

            <Color x:Key="ShareX.Color.Border">#1F1F1F</Color>
            <Color x:Key="ShareX.Color.Control.Background">#2E2E2E</Color>
            <Color x:Key="ShareX.Color.Control.Background.Hover">#3A3A3A</Color>
            <Color x:Key="ShareX.Color.Control.Border">#1F1F1F</Color>
            <Color x:Key="ShareX.Color.Separator">#333333</Color>
            <Color x:Key="ShareX.Color.TaskMode.Cancel.Background">#DC2626</Color>
            <Color x:Key="ShareX.Color.TaskMode.Cancel.Border">#EF4444</Color>
            <Color x:Key="ShareX.Color.TaskMode.Continue.Background">#10B981</Color>
            <Color x:Key="ShareX.Color.TaskMode.Continue.Border">#13DD9A</Color>
            <Color x:Key="ShareX.Color.TaskMode.Foreground">#FFFFFF</Color>

            <LinearGradientBrush x:Key="ShareX.Brush.Accent" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{StaticResource ShareX.Color.Accent.Start}" Offset="0" />
                <GradientStop Color="{StaticResource ShareX.Color.Accent.End}" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="ShareX.Brush.Accent.Start" Color="{StaticResource ShareX.Color.Accent.Start}" />
            <SolidColorBrush x:Key="ShareX.Brush.Accent.Foreground" Color="{StaticResource ShareX.Color.Accent.Foreground}" />

            <SolidColorBrush x:Key="ShareX.Brush.Text" Color="{StaticResource ShareX.Color.Text}" />
            <SolidColorBrush x:Key="ShareX.Brush.Text.Secondary" Color="{StaticResource ShareX.Color.Text.Secondary}" />

            <SolidColorBrush x:Key="ShareX.Brush.Background.Main" Color="{StaticResource ShareX.Color.Background.Main}" />
            <SolidColorBrush x:Key="ShareX.Brush.Background.Panel" Color="{StaticResource ShareX.Color.Background.Panel}" />
            <SolidColorBrush x:Key="ShareX.Brush.Background.Popup" Color="{StaticResource ShareX.Color.Background.Popup}" />
            <SolidColorBrush x:Key="ShareX.Brush.Background.Toolbar" Color="{StaticResource ShareX.Color.Background.Toolbar}" />

            <SolidColorBrush x:Key="ShareX.Brush.Border" Color="{StaticResource ShareX.Color.Border}" />
            <SolidColorBrush x:Key="ShareX.Brush.Control.Background" Color="{StaticResource ShareX.Color.Control.Background}" />
            <SolidColorBrush x:Key="ShareX.Brush.Control.Background.Hover" Color="{StaticResource ShareX.Color.Control.Background.Hover}" />
            <SolidColorBrush x:Key="ShareX.Brush.Control.Border" Color="{StaticResource ShareX.Color.Control.Border}" />
            <SolidColorBrush x:Key="ShareX.Brush.Control.Background.Disabled" Color="#383838" />
            <SolidColorBrush x:Key="ShareX.Brush.Separator" Color="{StaticResource ShareX.Color.Separator}" />
            <SolidColorBrush x:Key="ShareX.Brush.TaskMode.Cancel.Background" Color="{StaticResource ShareX.Color.TaskMode.Cancel.Background}" />
            <SolidColorBrush x:Key="ShareX.Brush.TaskMode.Cancel.Border" Color="{StaticResource ShareX.Color.TaskMode.Cancel.Border}" />
            <SolidColorBrush x:Key="ShareX.Brush.TaskMode.Continue.Background" Color="{StaticResource ShareX.Color.TaskMode.Continue.Background}" />
            <SolidColorBrush x:Key="ShareX.Brush.TaskMode.Continue.Border" Color="{StaticResource ShareX.Color.TaskMode.Continue.Border}" />
            <SolidColorBrush x:Key="ShareX.Brush.TaskMode.Foreground" Color="{StaticResource ShareX.Color.TaskMode.Foreground}" />
            <SolidColorBrush x:Key="ShareX.Brush.Overlay.Soft" Color="#30000000" />
            <SolidColorBrush x:Key="ShareX.Brush.Overlay.Modal" Color="#80000000" />

            <DrawingBrush x:Key="ShareX.Brush.Checkered" TileMode="Tile" SourceRect="0,0,30,30" DestinationRect="0,0,30,30">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#272727">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,30,30" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#2E2E2E">
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <RectangleGeometry Rect="0,0,15,15" />
                                    <RectangleGeometry Rect="15,15,15,15" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <DrawingBrush x:Key="ShareX.Brush.Checkered.Small" TileMode="Tile" SourceRect="0,0,8,8" DestinationRect="0,0,8,8">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#272727">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,8,8" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#2E2E2E">
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <RectangleGeometry Rect="0,0,4,4" />
                                    <RectangleGeometry Rect="4,4,4,4" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </ResourceDictionary>

        <!-- ShareX Light -->
        <ResourceDictionary x:Key="{x:Static helpers:ThemeManager.ShareXLight}">
            <Color x:Key="ShareX.Color.Accent.Start">#3E83F2</Color>
            <Color x:Key="ShareX.Color.Accent.End">#3975D5</Color>
            <Color x:Key="ShareX.Color.Accent.Foreground">#D8DADB</Color>

            <Color x:Key="ShareX.Color.Text">#4E4E4E</Color>
            <Color x:Key="ShareX.Color.Text.Secondary">#4E4E4E</Color>

            <Color x:Key="ShareX.Color.Background.Main">#F5F5F7</Color>
            <Color x:Key="ShareX.Color.Background.Panel">#FDFDFD</Color>
            <Color x:Key="ShareX.Color.Background.Popup">#FDFDFD</Color>
            <Color x:Key="ShareX.Color.Background.Toolbar">#FDFDFD</Color>

            <Color x:Key="ShareX.Color.Border">#E5E5E8</Color>
            <Color x:Key="ShareX.Color.Control.Background">#F5F5F7</Color>
            <Color x:Key="ShareX.Color.Control.Background.Hover">#EBEBEF</Color>
            <Color x:Key="ShareX.Color.Control.Border">#DBDBDF</Color>
            <Color x:Key="ShareX.Color.Separator">#E3E3E3</Color>
            <Color x:Key="ShareX.Color.TaskMode.Cancel.Background">#DC2626</Color>
            <Color x:Key="ShareX.Color.TaskMode.Cancel.Border">#EF4444</Color>
            <Color x:Key="ShareX.Color.TaskMode.Continue.Background">#10B981</Color>
            <Color x:Key="ShareX.Color.TaskMode.Continue.Border">#13DD9A</Color>
            <Color x:Key="ShareX.Color.TaskMode.Foreground">#FFFFFF</Color>

            <LinearGradientBrush x:Key="ShareX.Brush.Accent" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{StaticResource ShareX.Color.Accent.Start}" Offset="0" />
                <GradientStop Color="{StaticResource ShareX.Color.Accent.End}" Offset="1" />
            </LinearGradientBrush>
            <SolidColorBrush x:Key="ShareX.Brush.Accent.Start" Color="{StaticResource ShareX.Color.Accent.Start}" />
            <SolidColorBrush x:Key="ShareX.Brush.Accent.Foreground" Color="{StaticResource ShareX.Color.Accent.Foreground}" />

            <SolidColorBrush x:Key="ShareX.Brush.Text" Color="{StaticResource ShareX.Color.Text}" />
            <SolidColorBrush x:Key="ShareX.Brush.Text.Secondary" Color="{StaticResource ShareX.Color.Text.Secondary}" />

            <SolidColorBrush x:Key="ShareX.Brush.Background.Main" Color="{StaticResource ShareX.Color.Background.Main}" />
            <SolidColorBrush x:Key="ShareX.Brush.Background.Panel" Color="{StaticResource ShareX.Color.Background.Panel}" />
            <SolidColorBrush x:Key="ShareX.Brush.Background.Popup" Color="{StaticResource ShareX.Color.Background.Popup}" />
            <SolidColorBrush x:Key="ShareX.Brush.Background.Toolbar" Color="{StaticResource ShareX.Color.Background.Toolbar}" />

            <SolidColorBrush x:Key="ShareX.Brush.Border" Color="{StaticResource ShareX.Color.Border}" />
            <SolidColorBrush x:Key="ShareX.Brush.Control.Background" Color="{StaticResource ShareX.Color.Control.Background}" />
            <SolidColorBrush x:Key="ShareX.Brush.Control.Background.Hover" Color="{StaticResource ShareX.Color.Control.Background.Hover}" />
            <SolidColorBrush x:Key="ShareX.Brush.Control.Border" Color="{StaticResource ShareX.Color.Control.Border}" />
            <SolidColorBrush x:Key="ShareX.Brush.Control.Background.Disabled" Color="#AEAEB2" />
            <SolidColorBrush x:Key="ShareX.Brush.Separator" Color="{StaticResource ShareX.Color.Separator}" />
            <SolidColorBrush x:Key="ShareX.Brush.TaskMode.Cancel.Background" Color="{StaticResource ShareX.Color.TaskMode.Cancel.Background}" />
            <SolidColorBrush x:Key="ShareX.Brush.TaskMode.Cancel.Border" Color="{StaticResource ShareX.Color.TaskMode.Cancel.Border}" />
            <SolidColorBrush x:Key="ShareX.Brush.TaskMode.Continue.Background" Color="{StaticResource ShareX.Color.TaskMode.Continue.Background}" />
            <SolidColorBrush x:Key="ShareX.Brush.TaskMode.Continue.Border" Color="{StaticResource ShareX.Color.TaskMode.Continue.Border}" />
            <SolidColorBrush x:Key="ShareX.Brush.TaskMode.Foreground" Color="{StaticResource ShareX.Color.TaskMode.Foreground}" />
            <SolidColorBrush x:Key="ShareX.Brush.Overlay.Soft" Color="#30000000" />
            <SolidColorBrush x:Key="ShareX.Brush.Overlay.Modal" Color="#80000000" />

            <DrawingBrush x:Key="ShareX.Brush.Checkered" TileMode="Tile" SourceRect="0,0,30,30" DestinationRect="0,0,30,30">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#FFFFFF">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,30,30" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#EBEBEB">
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <RectangleGeometry Rect="0,0,15,15" />
                                    <RectangleGeometry Rect="15,15,15,15" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <DrawingBrush x:Key="ShareX.Brush.Checkered.Small" TileMode="Tile" SourceRect="0,0,8,8" DestinationRect="0,0,8,8">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#FFFFFF">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,8,8" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#EBEBEB">
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <RectangleGeometry Rect="0,0,4,4" />
                                    <RectangleGeometry Rect="4,4,4,4" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
