<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Application-wide style entry point.
        Keep reusable selectors and style classes here so views stay focused on layout and behavior.
    -->

    <Styles.Resources>
        <Thickness x:Key="ComboBoxDropdownContentMargin">6</Thickness>
    </Styles.Resources>

    <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
    <StyleInclude Source="avares://ShareX.ImageEditor/Presentation/Controls/EffectSlider.axaml" />

    <!-- Base typography -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource ShareX.FontFamily.Default}"/>
        <Setter Property="FontSize" Value="{DynamicResource ShareX.FontSize.Default}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
    </Style>

    <!-- Standard buttons -->
    <Style Selector="Button">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <!-- Explicitly override ContentPresenter backgrounds for all states so the Fluent
             ControlTheme's own ContentPresenter state setters don't bleed through. -->
        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="RenderTransform" Value="none"/>
        </Style>

        <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="^.active">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
        </Style>

        <Style Selector="^.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        </Style>

        <Style Selector="^.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        </Style>

        <Style Selector="^.active:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        </Style>

        <Style Selector="^.active /template/ ContentPresenter#PART_ContentPresenter TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
        </Style>

        <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="Opacity" Value="0.35"/>
        </Style>
    </Style>

    <Style Selector="Button.picker-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="4"/>

        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Disabled}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Disabled}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^.active">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
        </Style>

        <Style Selector="^.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        </Style>

        <Style Selector="^.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        </Style>

        <Style Selector="^.active:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        </Style>

        <Style Selector="^.active TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
        </Style>
    </Style>

    <Style Selector="Button.toolbar-button">
        <Setter Property="Width" Value="40"/>
        <Setter Property="MinWidth" Value="40"/>
        <Setter Property="FontFamily" Value="{DynamicResource ShareX.FontFamily.Icon}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="18"/>
    </Style>

    <Style Selector="Button.ratio-button">
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Width" Value="NaN"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <Style Selector="Button.transparent-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>

        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Style>

    <Style Selector="Button.task-mode-button">
        <Style Selector="^:pressed">
            <Setter Property="RenderTransform" Value="none"/>
        </Style>
    </Style>

    <Style Selector="Button.task-mode-button.danger">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.TaskMode.Cancel.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.TaskMode.Cancel.Border}"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.TaskMode.Foreground}"/>

        <Style Selector="^ > TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.TaskMode.Foreground}"/>
        </Style>

        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.TaskMode.Cancel.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.TaskMode.Cancel.Border}"/>
        </Style>

        <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.TaskMode.Cancel.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.TaskMode.Cancel.Border}"/>
            <Setter Property="Opacity" Value="0.35"/>
        </Style>
    </Style>

    <Style Selector="Button.task-mode-button.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.TaskMode.Cancel.Border}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.TaskMode.Cancel.Border}"/>
    </Style>

    <Style Selector="Button.task-mode-button.danger:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.TaskMode.Cancel.Border}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.TaskMode.Cancel.Border}"/>
    </Style>

    <Style Selector="Button.task-mode-button.success">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.TaskMode.Continue.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.TaskMode.Continue.Border}"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.TaskMode.Foreground}"/>

        <Style Selector="^ > TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.TaskMode.Foreground}"/>
        </Style>

        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.TaskMode.Continue.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.TaskMode.Continue.Border}"/>
        </Style>

        <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.TaskMode.Continue.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.TaskMode.Continue.Border}"/>
            <Setter Property="Opacity" Value="0.35"/>
        </Style>
    </Style>

    <Style Selector="Button.task-mode-button.success:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.TaskMode.Continue.Border}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.TaskMode.Continue.Border}"/>
    </Style>

    <Style Selector="Button.task-mode-button.success:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.TaskMode.Continue.Border}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.TaskMode.Continue.Border}"/>
    </Style>

    <!-- Shared surfaces -->
    <Style Selector="Border.popup-border">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="BoxShadow" Value="0 4 16 #40000000"/>
    </Style>

    <Style Selector="Border.popup-surface">
        <Setter Property="RenderTransformOrigin" Value="50%,0%"/>
        <Setter Property="RenderTransform" Value="translateY(-8px) scale(0.98)"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18"/>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.18"/>
            </Transitions>
        </Setter>

        <Style Selector="^.open">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="translateY(0px) scale(1)"/>
            <Setter Property="BoxShadow" Value="0 14 28 -14 #66000000"/>
        </Style>
    </Style>

    <Style Selector="Border.popup-surface.zoom-upward">
        <Setter Property="RenderTransformOrigin" Value="50%,100%"/>
        <Setter Property="RenderTransform" Value="translateY(8px) scale(0.98)"/>
    </Style>

    <Style Selector="Border.app-toast">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Background.Popup}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="BoxShadow" Value="0 14 28 -16 #70000000"/>

        <Style Selector="^ TextBlock:first-child">
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent}"/>
        </Style>
    </Style>

    <Style Selector="Border.floating-panel">
        <Setter Property="RenderTransformOrigin" Value="50%,0%"/>
        <Setter Property="RenderTransform" Value="translateY(-24px) scale(0.98)"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>

        <Style Selector="^.open">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="translateY(0px) scale(1)"/>
            <Setter Property="BoxShadow" Value="0 22 40 -22 #66000000"/>
        </Style>
    </Style>

    <Style Selector="Border.capsule">
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>

        <Style Selector="^ TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
        </Style>
    </Style>

    <Style Selector="Border.color-picker-popup">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Background.Popup}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <Style Selector="Border.color-preview-frame">
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="Border.checkered-surface">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Checkered.Small}"/>
    </Style>

    <!-- Editor layout primitives -->
    <Style Selector="TextBlock.dropdown-chevron">
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="RenderTransform" Value="rotate(0deg)"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.16"/>
            </Transitions>
        </Setter>

        <Style Selector="^.open">
            <Setter Property="RenderTransform" Value="rotate(180deg)"/>
        </Style>
    </Style>

    <Style Selector="Border.editor-sidebar">
        <Setter Property="Width" Value="0"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RenderTransform" Value="translateX(0px)"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Width" Duration="0:0:0.22"/>
                <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.22"/>
            </Transitions>
        </Setter>

        <Style Selector="^.left">
            <Setter Property="RenderTransform" Value="translateX(-18px)"/>
        </Style>

        <Style Selector="^.right">
            <Setter Property="RenderTransform" Value="translateX(18px)"/>
        </Style>

        <Style Selector="^.left > ScrollViewer > StackPanel > StackPanel:nth-child(1) > TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Start}"/>
            <Setter Property="Padding" Value="0,0,0,16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style Selector="^.right ContentControl > :is(UserControl) > StackPanel > StackPanel:nth-child(1) > TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Start}"/>
            <Setter Property="Padding" Value="0,0,0,16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style Selector="^.open">
            <Setter Property="Width" Value="282"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="translateX(0px)"/>
        </Style>

        <Style Selector="^.left.open">
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

        <Style Selector="^.right.open">
            <Setter Property="BorderThickness" Value="1,0,0,0"/>
        </Style>
    </Style>

    <Style Selector="Border.editor-toolbar-host">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="RenderTransform" Value="translateY(0px)"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>

        <Style Selector="^.top">
            <Setter Property="RenderTransformOrigin" Value="50%,0%"/>
        </Style>

        <Style Selector="^.bottom">
            <Setter Property="RenderTransformOrigin" Value="50%,100%"/>
        </Style>

        <Style Selector="^.top.hidden">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="translateY(-28px)"/>
        </Style>

        <Style Selector="^.bottom.hidden">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="translateY(28px)"/>
        </Style>
    </Style>

    <Style Selector="Grid.overlay-scrim">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Overlay.Soft}"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
            </Transitions>
        </Setter>

        <Style Selector="^.open">
            <Setter Property="Opacity" Value="1"/>
        </Style>
    </Style>

    <Style Selector="Border.modal-scrim">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Overlay.Modal}"/>
    </Style>

    <!-- Shared feature panels -->
    <Style Selector="TextBlock.category-header">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
        <Setter Property="Margin" Value="8,8,0,8"/>
    </Style>

    <Style Selector="Border.category-tip">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Background.Panel}"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <Style Selector="TextBlock.category-tip-icon">
        <Setter Property="FontFamily" Value="{DynamicResource ShareX.FontFamily.Icon}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,1,0,0"/>
    </Style>

    <Style Selector="Button.effect-item">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>

        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
        </Style>

        <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Style>

    <!-- Common control overrides -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="MinHeight" Value="40"/>

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Disabled}"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
        </Style>

        <Style Selector="^ /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="^:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        </Style>

        <Style Selector="^:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        </Style>

        <Style Selector="^:disabled /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Disabled}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        </Style>

        <Style Selector="^ /template/ TextPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        </Style>

        <Style Selector="^:disabled /template/ TextPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
        </Style>
    </Style>

    <Style Selector="TextBox.effect-search">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Style Selector="^ /template/ TextPresenter">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="MinHeight" Value="40"/>

        <!-- Target the Fluent template's background border directly so Fluent's own
             pseudo-class overrides on Border#Background don't bleed through. -->
        <Style Selector="^ /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="^:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        </Style>

        <Style Selector="^:pressed /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Disabled}"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
        </Style>

        <Style Selector="^:disabled /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Disabled}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        </Style>

        <Style Selector="^ /template/ TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="ComboBoxItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
    </Style>

    <!-- Fluent paints ComboBoxItem selection on the inner ContentPresenter. -->
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
    </Style>

    <Style Selector="ComboBoxItem:selected">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Accent}"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Accent}"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="ComboBoxItem:selected:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Accent}"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="ComboBoxItem:selected TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Disabled}"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
        </Style>

        <Style Selector="^ /template/ TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="^ /template/ TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^ /template/ TextBox:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        </Style>

        <Style Selector="^ /template/ TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^ /template/ TextBox:focus">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        </Style>

        <Style Selector="^ /template/ TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^ /template/ TextBox /template/ TextPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style Selector="^ /template/ TextBox:pointerover /template/ TextPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        </Style>

        <Style Selector="^ /template/ TextBox:focus /template/ TextPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        </Style>

        <Style Selector="^ /template/ ButtonSpinner > Button">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Disabled}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
            <Setter Property="MinWidth" Value="18"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="^ /template/ ButtonSpinner > Button:pointerover">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
        </Style>
    </Style>

    <Style Selector="Slider:horizontal">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent}"/>

        <Style Selector="^ /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="BorderThickness" Value="4"/>
        </Style>

        <Style Selector="^ /template/ Thumb:pointerover">
            <Setter Property="BorderThickness" Value="3"/>
        </Style>
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>

        <Style Selector="^ /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="^:not(:pointerover) /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="^:pointerover /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Hover}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        </Style>

        <Style Selector="^:checked /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
        </Style>

        <Style Selector="^:disabled /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background.Disabled}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Style>

    <Style Selector="ToggleSwitch">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text.Secondary}"/>
        </Style>

        <Style Selector="^:checked:not(:disabled) /template/ Border#SwitchKnobBounds">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Accent}"/>
        </Style>

        <Style Selector="^:checked:not(:disabled) /template/ Ellipse#SwitchKnobOn">
            <Setter Property="Fill" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
        </Style>

        <Style Selector="^:checked:not(:disabled):pointerover /template/ Border#SwitchKnobBounds">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Accent}"/>
        </Style>

        <Style Selector="^:checked:not(:disabled):pointerover /template/ Ellipse#SwitchKnobOn">
            <Setter Property="Fill" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
        </Style>

        <Style Selector="^:checked:not(:disabled):pressed /template/ Border#SwitchKnobBounds">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Accent}"/>
        </Style>

        <Style Selector="^:checked:not(:disabled):pressed /template/ Ellipse#SwitchKnobOn">
            <Setter Property="Fill" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
        </Style>
    </Style>

    <Style Selector="ToggleSwitch.side-panel-toggle-proxy">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Margin" Value="0,0,-12,0"/>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row">
        <Setter Property="Height" Value="NaN"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Style Selector="^:pressed">
            <Setter Property="RenderTransform" Value="none"/>
        </Style>

        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:checked:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Opacity" Value="0.35"/>
        </Style>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row:pointerover ToggleSwitch.side-panel-toggle-proxy /template/ Border#OuterBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource ToggleSwitchStrokeOffPointerOver}"/>
        <Setter Property="Background" Value="{DynamicResource ToggleSwitchFillOffPointerOver}"/>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row:pointerover ToggleSwitch.side-panel-toggle-proxy /template/ Ellipse#SwitchKnobOff">
        <Setter Property="Fill" Value="{DynamicResource ToggleSwitchKnobFillOffPointerOver}"/>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row:pointerover ToggleSwitch.side-panel-toggle-proxy /template/ Ellipse#SwitchKnobOn">
        <Setter Property="Fill" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row:pointerover ToggleSwitch.side-panel-toggle-proxy /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Accent}"/>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row:pointerover ToggleSwitch.side-panel-toggle-proxy /template/ Grid#SwitchAreaGrid">
        <Setter Property="Background" Value="{DynamicResource ToggleSwitchContainerBackgroundPointerOver}"/>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row:pressed ToggleSwitch.side-panel-toggle-proxy /template/ Border#OuterBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource ToggleSwitchStrokeOffPressed}"/>
        <Setter Property="Background" Value="{DynamicResource ToggleSwitchFillOffPressed}"/>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row:pressed ToggleSwitch.side-panel-toggle-proxy /template/ Ellipse#SwitchKnobOff">
        <Setter Property="Fill" Value="{DynamicResource ToggleSwitchKnobFillOffPressed}"/>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row:pressed ToggleSwitch.side-panel-toggle-proxy /template/ Ellipse#SwitchKnobOn">
        <Setter Property="Fill" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row:pressed ToggleSwitch.side-panel-toggle-proxy /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Accent}"/>
    </Style>

    <Style Selector="ToggleButton.side-panel-toggle-row:pressed ToggleSwitch.side-panel-toggle-proxy /template/ Grid#SwitchAreaGrid">
        <Setter Property="Background" Value="{DynamicResource ToggleSwitchContainerBackgroundPressed}"/>
    </Style>

    <Style Selector="Separator">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Separator}"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>

        <Style Selector="^ /template/ Border">
            <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Separator}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Separator}"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </Style>

    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Control.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShareX.Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style Selector="ContextMenu MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="ContextMenu MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
    </Style>

    <Style Selector="ContextMenu MenuItem:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="ContextMenu MenuItem:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="ContextMenu Separator">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Separator}"/>
    </Style>

    <Style Selector="MenuFlyoutPresenter MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Text}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="6,2"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="MenuFlyoutPresenter MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Accent}"/>
    </Style>

    <Style Selector="MenuFlyoutPresenter MenuItem:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="MenuFlyoutPresenter MenuItem:pointerover TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ShareX.Brush.Accent.Foreground}"/>
    </Style>

    <Style Selector="MenuFlyoutPresenter Separator">
        <Setter Property="Background" Value="{DynamicResource ShareX.Brush.Separator}"/>
        <Setter Property="Margin" Value="6,4"/>
    </Style>
</Styles>
