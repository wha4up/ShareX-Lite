<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:ShareX.ImageEditor.Presentation.Converters"
             xmlns:theming="using:ShareX.ImageEditor.Presentation.Theming"
             x:Class="ShareX.ImageEditor.Presentation.Controls.BorderStylePickerDropdown"
             x:Name="BorderStylePickerDropdownRoot"
             mc:Ignorable="d"
             d:DesignWidth="170"
             d:DesignHeight="40">
    <UserControl.Resources>
        <converters:BorderStyleDisplayConverter x:Key="BorderStyleDisplay" />
        <converters:BorderStylePreviewDashArrayConverter x:Key="BorderStylePreviewDashArray" />
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch">
        <Button x:Name="DropdownButton"
                Classes="app-button"
                Click="OnDropdownButtonClick"
                Height="40"
                MinWidth="{Binding MinWidth, ElementName=BorderStylePickerDropdownRoot}"
                MaxWidth="{Binding MaxWidth, ElementName=BorderStylePickerDropdownRoot}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding SelectedBorderStyle, ElementName=BorderStylePickerDropdownRoot, Converter={StaticResource BorderStyleDisplay}}"
                           Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                <Path Grid.Column="1"
                      Width="36"
                      Height="14"
                      Margin="8,0,8,0"
                      Data="M 2,7 L 34,7"
                      Stroke="{DynamicResource ShareX.Brush.Text.Secondary}"
                      StrokeThickness="1.75"
                      StrokeDashArray="{Binding SelectedBorderStyle, ElementName=BorderStylePickerDropdownRoot, Converter={StaticResource BorderStylePreviewDashArray}}"
                      StrokeLineCap="Flat"
                      Stretch="None"
                      VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2"
                           Classes="dropdown-chevron"
                           Classes.open="{Binding #BorderStylePopup.IsOpen}"
                           Text="{x:Static theming:EditorIcons.ChevronDown}"
                           FontFamily="{DynamicResource ShareX.FontFamily.Icon}"
                           FontWeight="Normal"
                           FontSize="10"
                           Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Button>

        <Popup x:Name="BorderStylePopup"
               PlacementTarget="{Binding #DropdownButton}"
               Placement="Bottom"
               IsLightDismissEnabled="True"
               VerticalOffset="4">
            <Border Classes="popup-border popup-surface"
                    Classes.open="{Binding #BorderStylePopup.IsOpen}">
                <ItemsControl ItemsSource="{Binding BorderStyleOptions, ElementName=BorderStylePickerDropdownRoot}"
                              HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button MinWidth="132"
                                    Height="32"
                                    Padding="8,0"
                                    Classes="picker-button"
                                    Click="OnBorderStyleSelected"
                                    CommandParameter="{Binding .}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Center"
                                    ToolTip.Tip="{Binding ., Converter={StaticResource BorderStyleDisplay}}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ., Converter={StaticResource BorderStyleDisplay}}"
                                               FontSize="14"
                                               Foreground="{DynamicResource ShareX.Brush.Text}"
                                               VerticalAlignment="Center"/>

                                    <Path Grid.Column="1"
                                          Width="36"
                                          Height="14"
                                          Margin="16,0,0,0"
                                          Data="M 2,7 L 34,7"
                                          Stroke="{DynamicResource ShareX.Brush.Text}"
                                          StrokeThickness="1.75"
                                          StrokeDashArray="{Binding ., Converter={StaticResource BorderStylePreviewDashArray}}"
                                          StrokeLineCap="Flat"
                                          Stretch="None"
                                          VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Popup>
    </Grid>
</UserControl>