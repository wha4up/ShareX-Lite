<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:ShareX.ImageEditor.Presentation.Converters"
             xmlns:theming="using:ShareX.ImageEditor.Presentation.Theming"
             x:Class="ShareX.ImageEditor.Presentation.Controls.ArrowStylePickerDropdown"
             x:Name="ArrowStylePickerDropdownRoot"
             mc:Ignorable="d"
             d:DesignWidth="160"
             d:DesignHeight="40">
    <UserControl.Resources>
        <converters:ArrowStylePreviewGeometryConverter x:Key="ArrowStylePreviewGeometry" />
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch">
        <Button x:Name="DropdownButton"
                Classes="app-button"
                Click="OnDropdownButtonClick"
                Height="40"
                MinWidth="{Binding MinWidth, ElementName=ArrowStylePickerDropdownRoot}"
                MaxWidth="{Binding MaxWidth, ElementName=ArrowStylePickerDropdownRoot}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Grid.Column="0"
                           Text="{Binding SelectedArrowStyle, ElementName=ArrowStylePickerDropdownRoot}"
                           Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                                <Path Grid.Column="1"
                                            Width="36"
                                            Height="14"
                                            Margin="8,0,8,0"
                                            Data="{Binding SelectedArrowStyle, ElementName=ArrowStylePickerDropdownRoot, Converter={StaticResource ArrowStylePreviewGeometry}}"
                                            Stroke="{DynamicResource ShareX.Brush.Text.Secondary}"
                                            Fill="{DynamicResource ShareX.Brush.Text.Secondary}"
                                            StrokeThickness="1.75"
                                            StrokeLineCap="Round"
                                            StrokeJoin="Round"
                                            Stretch="None"
                                            VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2"
                           Classes="dropdown-chevron"
                           Classes.open="{Binding #ArrowStylePopup.IsOpen}"
                           Text="{x:Static theming:EditorIcons.ChevronDown}"
                           FontFamily="{DynamicResource ShareX.FontFamily.Icon}"
                           FontWeight="Normal"
                           FontSize="10"
                           Foreground="{DynamicResource ShareX.Brush.Text.Secondary}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Button>

        <Popup x:Name="ArrowStylePopup"
               PlacementTarget="{Binding #DropdownButton}"
               Placement="Bottom"
               IsLightDismissEnabled="True"
               VerticalOffset="4">
            <Border Classes="popup-border popup-surface"
                    Classes.open="{Binding #ArrowStylePopup.IsOpen}">
                <ItemsControl ItemsSource="{Binding ArrowStyleOptions, ElementName=ArrowStylePickerDropdownRoot}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                                <Button MinWidth="122"
                                    Height="32"
                                    Padding="8,0"
                                    Classes="picker-button"
                                    Click="OnArrowStyleSelected"
                                    CommandParameter="{Binding .}"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Center"
                                    ToolTip.Tip="{Binding .}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding .}"
                                               FontSize="14"
                                               Foreground="{DynamicResource ShareX.Brush.Text}"
                                               VerticalAlignment="Center"/>

                                    <Path Grid.Column="1"
                                          Width="36"
                                          Height="14"
                                          Margin="8,0,0,0"
                                          Data="{Binding ., Converter={StaticResource ArrowStylePreviewGeometry}}"
                                          Stroke="{DynamicResource ShareX.Brush.Text}"
                                          Fill="{DynamicResource ShareX.Brush.Text}"
                                          StrokeThickness="1.75"
                                          StrokeLineCap="Round"
                                          StrokeJoin="Round"
                                          Stretch="None"
                                          VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Popup>
    </Grid>
</UserControl>